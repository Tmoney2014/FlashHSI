<Window x:Class="FlashHSI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:FlashHSI.UI.ViewModels"
        xmlns:pages="clr-namespace:FlashHSI.UI.Views.Pages"
        xmlns:materialDesignDialogHost="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        mc:Ignorable="d"
        Title="FlashHSI - High Speed Sorter" Height="1080" Width="1920"
        Closing="Window_Closing"
        d:DataContext="{d:DesignInstance vm:MainViewModel, IsDesignTimeCreatable=False}">
    
    <materialDesignDialogHost:DialogHost Identifier="RootDialog">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header / Status Bar -->
        <materialDesign:ColorZone Mode="PrimaryMid" Padding="16" materialDesign:ShadowAssist.ShadowDepth="Depth2">
            <DockPanel LastChildFill="False">
                <!-- 타이틀 -->
                <TextBlock Text="Flash HSI Sorter" VerticalAlignment="Center" 
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           DockPanel.Dock="Left"/>
                
                <!-- 오른쪽: 상태 메시지 + 종료 버튼 -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                     
                     <!-- 종료 버튼 (원형, 빨간색, 가장 오른쪽) -->
                     <Button Click="ExitButton_Click"
                             ToolTip="Exit Application"
                             Width="40" Height="40"
                             Padding="0"
                             Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                             Background="#E53935"
                             BorderBrush="#E53935">
                         <materialDesign:PackIcon Kind="Power" Width="20" Height="20"/>
                     </Button>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Background="{DynamicResource MaterialDesignPaper}" Margin="8"
                    Style="{StaticResource MaterialDesignNavigationRailTabControl}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    x:Name="MainTabControl">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Width="Auto" Height="Auto">
                        <materialDesign:PackIcon Kind="Home" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Home" HorizontalAlignment="Center" FontSize="10"/>
                    </StackPanel>
                </TabItem.Header>
                <pages:HomeView DataContext="{Binding HomeVM}"/>
            </TabItem>
            
             <TabItem>
                <TabItem.Header>
                    <StackPanel Width="Auto" Height="Auto">
                        <materialDesign:PackIcon Kind="Eye" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Live View" HorizontalAlignment="Center" FontSize="10"/>
                    </StackPanel>
                </TabItem.Header>
                <!-- LiveView uses LiveVM for camera control and Waterfall Image -->
                <pages:LiveView DataContext="{Binding LiveVM}"/> 
            </TabItem>
            
            <TabItem>
                <TabItem.Header>
                    <StackPanel Width="Auto" Height="Auto">
                        <materialDesign:PackIcon Kind="ChartBar" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Statistic" HorizontalAlignment="Center" FontSize="10"/>
                    </StackPanel>
                </TabItem.Header>
                <pages:StatisticView DataContext="{Binding StatisticVM}"/>
            </TabItem>
            
            <TabItem>
                <TabItem.Header>
                    <StackPanel Width="Auto" Height="Auto">
                        <materialDesign:PackIcon Kind="Cog" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Settings" HorizontalAlignment="Center" FontSize="10"/>
                    </StackPanel>
                </TabItem.Header>
                <pages:SettingView DataContext="{Binding SettingVM}"/>
            </TabItem>
            
            <TabItem>
                <TabItem.Header>
                    <StackPanel Width="Auto" Height="Auto">
                        <materialDesign:PackIcon Kind="History" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Logs" HorizontalAlignment="Center" FontSize="10"/>
                    </StackPanel>
                </TabItem.Header>
                <pages:LogView DataContext="{Binding LogVM}"/>
            </TabItem>
        </TabControl>
        
        <!-- Bottom Status Bar (Optional) -->
        <StatusBar Grid.Row="2" Background="#333">
             <StatusBarItem>
                 <TextBlock Text="{Binding StatusMessage}" Foreground="White"/>
             </StatusBarItem>
        </StatusBar>
        
        <!-- AI가 추가함: Busy 상태 로딩 오버레이 -->
        <Border Grid.Row="1"
                Background="#AA000000"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" CornerRadius="24" Padding="64,48"
                    HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="400">
                <StackPanel>
                    <!-- 로딩 스피너 -->
                    <Grid Height="96" Width="96" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Stroke="#2196F3" StrokeThickness="8" Stretch="Uniform"/>
                        <Ellipse Stroke="#E0E0E0" StrokeThickness="8" StrokeDashArray="24 8"
                                 Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="LoadingSpinnerRotation"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetName="LoadingSpinnerRotation"
                                                Storyboard.TargetProperty="Angle"
                                                From="0" To="360" Duration="0:0:1.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <!-- 로딩 텍스트 -->
                    <TextBlock Margin="10" Text="Loading..."
                               HorizontalAlignment="Center" FontSize="40"
                               FontWeight="Medium" Foreground="#424242"/>
                </StackPanel>
            </Border>
        </Border>
        
        <!-- AI가 추가함: 종료 정보 오버레이 (람프 냉각 대기) -->
        <Border Grid.Row="1"
                Background="#99000000"
                Panel.ZIndex="2000"
                Visibility="{Binding IsExiting, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource MaterialDesignPaper}"
                    CornerRadius="16" Padding="40,32"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="380" MaxWidth="450">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="30" ShadowDepth="5"/>
                </Border.Effect>
                
                <StackPanel>
                    <!-- 종료 아이콘 -->
                    <materialDesign:PackIcon Kind="Power"
                                             Width="56" Height="56"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                             HorizontalAlignment="Center"
                                             Margin="0,0,0,16"/>
                    
                    <!-- 종료 안내 텍스트 -->
                    <TextBlock Text="Shutting Down..."
                               FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,24"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
                    
                    <!-- 램프 상태 -->
                    <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                            CornerRadius="12" Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 전구 아이콘 -->
                            <materialDesign:PackIcon Grid.Column="0"
                                                     Kind="Lightbulb"
                                                     Width="24" Height="24"
                                                     Foreground="#FF9800"
                                                     VerticalAlignment="Center"/>
                            
                            <!-- 텍스트 -->
                            <TextBlock Grid.Column="1"
                                       Text="Lamp Temperature"
                                       FontSize="14" FontWeight="Medium"
                                       VerticalAlignment="Center" Margin="12,0"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
                            
                            <!-- 퍼센트 -->
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center" FontWeight="Bold"
                                       Foreground="#FF9800">
                                <Run Text="{Binding LampCoolingPercent, StringFormat={}{0:F0}}"/><Run Text="%"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                    
                    <!-- 상태 메시지 -->
                    <TextBlock Text="{Binding ExitStatusMessage}"
                               FontSize="13"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                               HorizontalAlignment="Center" Margin="0,8,0,16"
                               Opacity="0.8"/>
                    
                    <!-- 지금 종료 버튼 -->
                    <Button Content="Exit Now"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding ImmediateExitCommand}"
                            Width="180" Height="40"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
        
        <!-- AI가 추가함: Snackbar 알림 (하단 오버레이) -->
        <materialDesign:Snackbar Grid.Row="1" MessageQueue="{Binding SnackbarQueue}"
                                  HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                  Margin="0,0,0,8"/>
    </Grid>
    </materialDesignDialogHost:DialogHost>
</Window>
