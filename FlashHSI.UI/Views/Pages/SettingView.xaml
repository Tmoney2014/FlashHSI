<UserControl x:Class="FlashHSI.UI.Views.Pages.SettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:FlashHSI.UI.Behaviors"
             xmlns:converters="clr-namespace:FlashHSI.UI.Converters"
             xmlns:local1="clr-namespace:FlashHSI.Core.Engine;assembly=FlashHSI.Core"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    
    <UserControl.Resources>
        <system:Double x:Key="TabControlWidth">160</system:Double>
        <converters:HexToColorBrushConverter x:Key="HexToColorBrushConverter"/>
        <converters:MaskModeToBoolConverter x:Key="MaskModeToBoolConverter"/>
        <converters:MaskModeToVisibilityConverter x:Key="MaskModeToVisibilityConverter"/>
        <converters:OperatorToColorConverter x:Key="OperatorToColorConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <TabControl TabStripPlacement="Left"
                    Style="{StaticResource MaterialDesignNavigationRailTabControl}"
                    materialDesign:ColorZoneAssist.Mode="PrimaryMid"
                    materialDesign:NavigationRailAssist.ShowSelectionBackground="True"
                    materialDesign:NavigationRailAssist.SelectionCornerRadius="5">
            
            <!-- 1. CAMERA TAB -->
            <TabItem Width="{StaticResource TabControlWidth}" Height="60">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Camera" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Camera" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel MaxWidth="1200" HorizontalAlignment="Stretch">
                        <TextBlock Text="Camera Settings" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,20"/>

                        <!-- Refresh All Button -->
                        <DockPanel Margin="0,0,0,16" IsEnabled="{Binding IsCameraConnected}">
                            <Button Command="{Binding RefreshAllCameraParametersCommand}" 
                                    Style="{StaticResource MaterialDesignRaisedButton}" Height="36" Padding="16,0"
                                    IsEnabled="{Binding IsCameraRefreshing, Converter={StaticResource InverseBooleanConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Refresh All Parameters" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" 
                                         IsIndeterminate="True" Width="20" Height="20" Margin="12,0,0,0"
                                         Visibility="{Binding IsCameraRefreshing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </DockPanel>

                        <!-- 1. Parameters (기존 — ExposureTime, FPS) -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Parameters" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Exposure Time (μs)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraExposureTime, StringFormat=N3}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraExposureMin}" Maximum="{Binding CameraExposureMax}" Value="{Binding CameraExposureTime, UpdateSourceTrigger=Explicit}" TickFrequency="0.001" IsSnapToTickEnabled="False" VerticalAlignment="Center"
                                            behaviors:SliderValuePopupBehavior.Format="N3">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Acquisition FPS" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraFrameRate, StringFormat=N0}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraFpsMin}" Maximum="{Binding CameraFpsMax}" Value="{Binding CameraFrameRate, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="False" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Measured FPS" Width="180" VerticalAlignment="Center" Foreground="Gray"/>
                                    <TextBlock Text="{Binding CameraFrameRateMeasured, StringFormat=N2}" VerticalAlignment="Center" Foreground="Gray"/>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- MROI -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="MROI Band Regions" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <TextBlock Text="OFF" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="Gray" FontSize="11"/>
                                        <ToggleButton IsChecked="{Binding IsMroiEnabled}" 
                                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                      VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="ON" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="Gray" FontSize="11"/>
                                        <Button Command="{Binding ApplyMroiSettingsCommand}" Content="Apply to Camera" 
                                                Style="{StaticResource MaterialDesignRaisedButton}" 
                                                Height="28" Padding="12,0" FontSize="11"/>
                                    </StackPanel>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Band Indices" Width="140" VerticalAlignment="Center" FontWeight="Medium"/>
                                    <TextBox Text="{Binding MroiBandsText, UpdateSourceTrigger=PropertyChanged}" 
                                             TextAlignment="Left" VerticalAlignment="Center" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                             Height="30" Padding="4,4"/>
                                </DockPanel>
                                <TextBlock Text="※ 모델 로드 시 RequiredRawBands에서 자동 구성됩니다. 쉼표로 구분된 밴드 인덱스를 수동 입력할 수도 있습니다." 
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Calibration References -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Calibration References" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="White Reference" Width="140" VerticalAlignment="Center" FontWeight="Medium"/>
                                    <materialDesign:PackIcon DockPanel.Dock="Left" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="CloseCircle"/>
                                                <Setter Property="Foreground" Value="#F44336"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWhiteRefLoaded}" Value="True">
                                                        <Setter Property="Kind" Value="CheckCircle"/>
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                    <Button DockPanel.Dock="Right" Command="{Binding LoadWhiteRefCommand}" Content="Select File"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="8,0" Margin="8,0,0,0"/>
                                    <TextBox Text="{Binding WhiteRefPath, Mode=OneWay}" TextAlignment="Left" VerticalAlignment="Center" IsReadOnly="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="30" Padding="4,4"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Dark Reference" Width="140" VerticalAlignment="Center" FontWeight="Medium"/>
                                    <materialDesign:PackIcon DockPanel.Dock="Left" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="CloseCircle"/>
                                                <Setter Property="Foreground" Value="#F44336"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDarkRefLoaded}" Value="True">
                                                        <Setter Property="Kind" Value="CheckCircle"/>
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                    <Button DockPanel.Dock="Right" Command="{Binding LoadDarkRefCommand}" Content="Select File"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="8,0" Margin="8,0,0,0"/>
                                    <TextBox Text="{Binding DarkRefPath, Mode=OneWay}" TextAlignment="Left" VerticalAlignment="Center" IsReadOnly="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="30" Padding="4,4"/>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 2. Sensor & Binning -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16" IsEnabled="{Binding IsCameraConnected}">
                            <StackPanel>
                                <TextBlock Text="Sensor &amp; Binning" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Binning Horizontal" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraBinningH}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraBinningHMin}" Maximum="{Binding CameraBinningHMax}" Value="{Binding CameraBinningH, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Binning Vertical" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraBinningV}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraBinningVMin}" Maximum="{Binding CameraBinningVMax}" Value="{Binding CameraBinningV, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Width" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraWidth}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraWidthMin}" Maximum="{Binding CameraWidthMax}" Value="{Binding CameraWidth, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Height" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraHeight}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraHeightMin}" Maximum="{Binding CameraHeightMax}" Value="{Binding CameraHeight, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Offset X" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraOffsetX}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraOffsetXMin}" Maximum="{Binding CameraOffsetXMax}" Value="{Binding CameraOffsetX, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Offset Y" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraOffsetY}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraOffsetYMin}" Maximum="{Binding CameraOffsetYMax}" Value="{Binding CameraOffsetY, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 3. Acquisition -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16" IsEnabled="{Binding IsCameraConnected}">
                            <StackPanel>
                                <TextBlock Text="Acquisition" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Mode" Width="180" VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding CameraAcquisitionModeOptions}" SelectedItem="{Binding CameraAcquisitionMode}" MinWidth="150"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Frame Count" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraAcquisitionFrameCount}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraAcquisitionFrameCountMin}" Maximum="1000" Value="{Binding CameraAcquisitionFrameCount, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Timeout (ms)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraAcquisitionTimeout}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraAcquisitionTimeoutMin}" Maximum="30000" Value="{Binding CameraAcquisitionTimeout, UpdateSourceTrigger=Explicit}" TickFrequency="100" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 4. Trigger -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16" IsEnabled="{Binding IsCameraConnected}">
                            <StackPanel>
                                <TextBlock Text="Trigger" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Trigger Mode" Width="180" VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding CameraTriggerModeOptions}" SelectedItem="{Binding CameraTriggerMode}" MinWidth="150"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Trigger Source" Width="180" VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding CameraTriggerSourceOptions}" SelectedItem="{Binding CameraTriggerSource}" MinWidth="150"/>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 5. Readout & Network -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16" IsEnabled="{Binding IsCameraConnected}">
                            <StackPanel>
                                <TextBlock Text="Readout &amp; Network" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Readout Mode" Width="180" VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding CameraReadoutModeOptions}" SelectedItem="{Binding CameraReadoutMode}" MinWidth="150"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Output Format" Width="180" VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding CameraOutputFormatOptions}" SelectedItem="{Binding CameraOutputFormat}" MinWidth="150"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Resend Buffer Size" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraResendBufferSize}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraResendBufferSizeMin}" Maximum="{Binding CameraResendBufferSizeMax}" Value="{Binding CameraResendBufferSize, UpdateSourceTrigger=Explicit}" TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Packet Size" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraPacketSize}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraPacketSizeMin}" Maximum="{Binding CameraPacketSizeMax}" Value="{Binding CameraPacketSize, UpdateSourceTrigger=Explicit}" TickFrequency="64" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Heartbeat Timeout (ms)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraHeartbeatTimeout}" Width="80" DockPanel.Dock="Right" TextAlignment="Right" IsReadOnly="True"/>
                                    <Slider Minimum="{Binding CameraHeartbeatTimeoutMin}" Maximum="30000" Value="{Binding CameraHeartbeatTimeout, UpdateSourceTrigger=Explicit}" TickFrequency="100" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <Separator Margin="0,8"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Network Performance" Width="180" VerticalAlignment="Center"/>
                                    <ToggleButton IsChecked="{Binding CameraNetworkingPerformanceEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Image Embedding" Width="180" VerticalAlignment="Center"/>
                                    <ToggleButton IsChecked="{Binding CameraImageEmbeddingEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 6. Shutter & Stabilization -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16" IsEnabled="{Binding IsCameraConnected}">
                            <StackPanel>
                                <TextBlock Text="Shutter &amp; Stabilization" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Shutter State" Width="180" VerticalAlignment="Center" Foreground="Gray"/>
                                    <TextBlock Text="{Binding CameraShutterState}" VerticalAlignment="Center" Foreground="Gray"/>
                                </DockPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Command="{Binding CameraShutterOpenCommand}" Content="Shutter Open" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="12,0" Margin="0,0,8,0"/>
                                    <Button Command="{Binding CameraShutterCloseCommand}" Content="Shutter Close" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="12,0"/>
                                </StackPanel>
                                <Separator Margin="0,4"/>
                                <DockPanel Margin="0,10,0,10">
                                    <TextBlock Text="Stabilization Enabled" Width="180" VerticalAlignment="Center"/>
                                    <ToggleButton IsChecked="{Binding CameraStabilizationEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Is Stable" Width="180" VerticalAlignment="Center" Foreground="Gray"/>
                                    <TextBlock Text="{Binding CameraStabilizationIsStable}" VerticalAlignment="Center" Foreground="Gray"/>
                                </DockPanel>
                                <Button Command="{Binding CameraStabilizationUpdateCommand}" Content="Update Stabilization" 
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="12,0" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 7. Preprocessing & References -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16" IsEnabled="{Binding IsCameraConnected}">
                            <StackPanel>
                                <TextBlock Text="Preprocessing &amp; References" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Preprocessing Enabled" Width="180" VerticalAlignment="Center"/>
                                    <ToggleButton IsChecked="{Binding CameraPreprocessingEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="References Lock" Width="180" VerticalAlignment="Center"/>
                                    <ToggleButton IsChecked="{Binding CameraReferencesLock}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </DockPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Command="{Binding CameraDarkCreateCommand}" Content="Create Dark Ref" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="12,0" Margin="0,0,8,0"/>
                                    <Button Command="{Binding CameraWhiteCreateCommand}" Content="Create White Ref" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="12,0"/>
                                </StackPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 8. User Set -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16" IsEnabled="{Binding IsCameraConnected}">
                            <StackPanel>
                                <TextBlock Text="User Set" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Selector" Width="180" VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding CameraUserSetSelectorOptions}" SelectedItem="{Binding CameraUserSetSelector}" MinWidth="150"/>
                                </DockPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Command="{Binding CameraUserSetLoadCommand}" Content="Load" 
                                            Style="{StaticResource MaterialDesignRaisedButton}" Height="30" Padding="16,0" Margin="0,0,8,0"/>
                                    <Button Command="{Binding CameraUserSetSaveCommand}" Content="Save" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="16,0"/>
                                </StackPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 9. Temperature Monitor -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16" IsEnabled="{Binding IsCameraConnected}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <TextBlock Text="Temperature Monitor" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
                                    <Button Command="{Binding CameraTemperatureUpdateCommand}" Content="Update" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="28" Padding="12,0" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <UniformGrid Columns="2" Margin="0,0,0,0">
                                    <DockPanel Margin="0,0,16,8">
                                        <TextBlock Text="FPA (K)" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
                                        <TextBlock Text="{Binding CameraTemperatureFPA, StringFormat=N2}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="FPGA (°C)" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
                                        <TextBlock Text="{Binding CameraTemperatureFPGA, StringFormat=N2}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,16,8">
                                        <TextBlock Text="Board (°C)" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
                                        <TextBlock Text="{Binding CameraTemperatureBoard, StringFormat=N2}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Hot Plate (°C)" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
                                        <TextBlock Text="{Binding CameraTemperatureScb1, StringFormat=N2}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,16,8">
                                        <TextBlock Text="Optics (°C)" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
                                        <TextBlock Text="{Binding CameraTemperatureScb2, StringFormat=N2}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Shutter (°C)" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
                                        <TextBlock Text="{Binding CameraTemperatureScb3, StringFormat=N2}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </UniformGrid>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 10. Device Info (RO) -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16" IsEnabled="{Binding IsCameraConnected}">
                            <StackPanel>
                                <TextBlock Text="Device Info" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Model" Width="180" VerticalAlignment="Center" Foreground="Gray"/>
                                    <TextBlock Text="{Binding CameraDeviceModelName}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Serial Number" Width="180" VerticalAlignment="Center" Foreground="Gray"/>
                                    <TextBlock Text="{Binding CameraDeviceSerialNumber}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Firmware" Width="180" VerticalAlignment="Center" Foreground="Gray"/>
                                    <TextBlock Text="{Binding CameraDeviceVersion}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Separator Margin="0,8"/>
                                <Button Command="{Binding CameraDeviceResetCommand}" Content="Device Reset" 
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="12,0" HorizontalAlignment="Left"
                                        Foreground="#F44336" BorderBrush="#F44336"/>
                            </StackPanel>
                        </materialDesign:Card>


                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 2. AIR GUN TAB (Injection) -->
            <TabItem Width="{StaticResource TabControlWidth}" Height="60">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AirFilter" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Air Gun" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel MaxWidth="1200" HorizontalAlignment="Stretch">
                        <TextBlock Text="Ejection &amp; Tracking" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,20"/>

                        <!-- AI가 추가함: 비상 정지 카드 (가장 위) -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16" Background="#B71C1C">
                            <Button Command="{Binding EmergencyStopCommand}" 
                                    Content="EMERGENCY STOP" 
                                    FontSize="18" FontWeight="Bold"
                                    Foreground="White" Background="#D32F2F" BorderBrush="#D32F2F"
                                    Height="50"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </materialDesign:Card>

                        <!-- Ejection Logic -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Ejection Parameters" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                
                                <DockPanel Margin="0,0,0,10" ToolTip="Detection to Fire Delay">
                                    <TextBlock Text="Base Delay (ms)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding EjectionDelayMs}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="0" Maximum="500" Value="{Binding EjectionDelayMs, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                
                                <!-- Y-Based Correction Rules -->
                                <materialDesign:Card Margin="0,0,0,10" Padding="8">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="Y-Correction Rules" VerticalAlignment="Center" FontWeight="Bold"/>
                                            <Button Command="{Binding AddYCorrectionRuleCommand}" Content="Add Rule" 
                                                    Style="{StaticResource MaterialDesignFlatButton}" 
                                                    Foreground="White"
                                                    Height="24" Padding="8,0" FontSize="10" 
                                                    DockPanel.Dock="Right"/>
                                        </DockPanel>
                                        
                                        <ItemsControl ItemsSource="{Binding YCorrectionRules}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <materialDesign:Card Margin="0,0,0,8" Padding="8">
                                                        <StackPanel>
                                                            <DockPanel Margin="0,0,0,4">
                                                                <TextBlock Text="Rule" VerticalAlignment="Center" Foreground="Gray" FontSize="10"/>
                                                                <Button Command="{Binding DataContext.RemoveYCorrectionRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                        Width="20" Height="20"
                                                                        HorizontalAlignment="Right"
                                                                        DockPanel.Dock="Right"
                                                                        ToolTip="Remove Rule">
                                                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                                                                </Button>
                                                            </DockPanel>

                                                            <DockPanel Margin="0,0,0,4">
                                                                <TextBlock Text="Threshold Y (Px)" VerticalAlignment="Center" Width="100"/>
                                                                <TextBox Text="{Binding ThresholdY, StringFormat=N0}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                                                         behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                                                <Slider Minimum="0" Maximum="1024" Value="{Binding ThresholdY, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                                                    <i:Interaction.Behaviors>
                                                                        <behaviors:SliderDragCompletedBehavior/>
                                                                        <behaviors:SliderValuePopupBehavior/>
                                                                        <behaviors:SliderButtonBehavior/>
                                                                    </i:Interaction.Behaviors>
                                                                </Slider>
                                                            </DockPanel>

                                                            <DockPanel>
                                                                <TextBlock Text="Correction (ms)" VerticalAlignment="Center" Width="100"/>
                                                                <TextBox Text="{Binding CorrectionMs, StringFormat=N0}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                                                         behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                                                <Slider Minimum="-20" Maximum="20" Value="{Binding CorrectionMs, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                                                    <i:Interaction.Behaviors>
                                                                        <behaviors:SliderDragCompletedBehavior/>
                                                                        <behaviors:SliderValuePopupBehavior/>
                                                                        <behaviors:SliderButtonBehavior/>
                                                                    </i:Interaction.Behaviors>
                                                                </Slider>
                                                            </DockPanel>
                                                        </StackPanel>
                                                    </materialDesign:Card>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </materialDesign:Card>
                                
                                <DockPanel Margin="0,0,0,10" ToolTip="Valve Open Duration">
                                    <TextBlock Text="Duration (ms)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding EjectionDurationMs}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="5" Maximum="200" Value="{Binding EjectionDurationMs, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                
                                <DockPanel Margin="0,0,0,0" ToolTip="Extra valves around center">
                                    <TextBlock Text="Blow Margin (Valves)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding EjectionBlowMargin}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="0" Maximum="5" Value="{Binding EjectionBlowMargin, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- AI가 추가함: EtherCAT 연결 카드 -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="EtherCAT Connection" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Network Interface" Width="180" VerticalAlignment="Center"/>
                                    <Button Content="↻" Command="{Binding RefreshNetworkInterfacesCommand}" 
                                            Style="{StaticResource MaterialDesignIconButton}" DockPanel.Dock="Right" Width="32" Height="32" ToolTip="Refresh"/>
                                    <ComboBox ItemsSource="{Binding NetworkInterfaces}" SelectedItem="{Binding SelectedNetworkInterface}"/>
                                </DockPanel>

                                <!-- AI가 수정함: File Path 탭과 동일한 스타일로 통일 -->
                                <DockPanel Margin="0,0,0,10" ToolTip="EtherCAT ESI Directory">
                                    <TextBlock Text="ESI Directory" Width="180" VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right" Command="{Binding SelectEsiDirectoryCommand}" Content="Select Folder"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="8,0" Margin="8,0,0,0"/>
                                    <TextBox Text="{Binding EsiDirectoryPath}" TextAlignment="Left" VerticalAlignment="Center" IsReadOnly="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="30" Padding="4,4"/>
                                </DockPanel>
                                
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Cycle Frequency (Hz)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding EtherCATCycleFrequency}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="100" Maximum="2000" Value="{Binding EtherCATCycleFrequency, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,10" ToolTip="Camera FOV (mm)">
                                    <TextBlock Text="Field of View (mm)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding FieldOfView}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="0" Maximum="2000" Value="{Binding FieldOfView, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,10" ToolTip="Air Gun Valve Channel Count">
                                    <TextBlock Text="Channel Count" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding AirGunChannelCount}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="1" Maximum="200" Value="{Binding AirGunChannelCount, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,10" ToolTip="Camera Sensor Width (pixels)">
                                    <TextBlock Text="Sensor Size (px)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CameraSensorSize}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="1" Maximum="1024" Value="{Binding CameraSensorSize, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                
                                <CheckBox Content="Channel Reverse" IsChecked="{Binding IsChannelReverse}" Margin="0,0,0,10"/>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding ConnectEtherCATCommand}" Content="Connect" Margin="0,0,8,0"
                                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                                    <Button Grid.Column="1" Command="{Binding DisconnectEtherCATCommand}" Content="Disconnect" Margin="8,0,0,0"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                </Grid>
                                
                                <TextBlock Text="{Binding AirGunStatusText}" Margin="0,8,0,0" Foreground="Gray" FontSize="12"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- AI가 추가함: Master Control 카드 -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Master Control" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel>
                                    <TextBlock Text="Master ON/OFF" Width="180" VerticalAlignment="Center"/>
                                    <ToggleButton IsChecked="{Binding IsMasterOn}" Command="{Binding ToggleMasterCommand}"
                                                  Style="{StaticResource MaterialDesignSwitchToggleButton}" DockPanel.Dock="Right"/>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- AI가 추가함: Air Gun Test 카드 -->
                        <materialDesign:Card Padding="16">
                            <StackPanel>
                                <TextBlock Text="Air Gun Test" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Start Channel" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding TestStartChannel}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="1" Maximum="{Binding AirGunChannelCount}" Value="{Binding TestStartChannel, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Blow Time (ms)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding TestBlowTime}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="10" Maximum="500" Value="{Binding TestBlowTime, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Delay Between (ms)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding TestDelay}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="50" Maximum="2000" Value="{Binding TestDelay, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding TestAllChannelsCommand}" Content="Test All Channels" Margin="0,0,8,0"
                                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                                    <Button Grid.Column="1" Command="{Binding CancelTestAllChannelsCommand}" Content="Cancel Test" Margin="8,0,0,0"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                </Grid>
                                
                                <Separator Margin="0,16"/>
                                
                                <TextBlock Text="Single Channel Test" FontWeight="Bold" Margin="0,0,0,10"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Channel" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding TestSingleChannel}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="1" Maximum="{Binding AirGunChannelCount}" Value="{Binding TestSingleChannel, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                                <Button Command="{Binding TestSingleChannelCommand}" Content="Fire Single Channel"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 2-1. OBJECT TAB (AI가 추가함: Classification + Background + Object Tracking) -->
            <TabItem Width="{StaticResource TabControlWidth}" Height="60">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cube" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Object" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel MaxWidth="1200" HorizontalAlignment="Stretch">
                        <TextBlock Text="Object Detection &amp; Classification" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,20"/>

                        <!-- Classification Threshold -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Classification" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>

                                <DockPanel Margin="0,0,0,10" ToolTip="모델에서 Confidence 임계값. 이 값 이하의 분류 결과는 Unknown으로 처리">
                                    <TextBlock Text="Confidence Threshold" Width="200" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding ConfidenceThreshold, StringFormat=F2}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="0" Maximum="1" Value="{Binding ConfidenceThreshold, UpdateSourceTrigger=Explicit}" TickFrequency="0.01" IsSnapToTickEnabled="False"
                                            VerticalAlignment="Center" behaviors:SliderValuePopupBehavior.Format="F2">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Background Threshold -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Background" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>

                                <!-- Mask Mode Selection -->
                                <DockPanel Margin="0,0,0,10" ToolTip="배경 마스킹 방식 선택">
                                    <TextBlock Text="Mask Mode" Width="200" VerticalAlignment="Center"/>
                                    <ComboBox SelectedValue="{Binding SelectedMaskMode}" SelectedValuePath="Tag" Width="120" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <ComboBoxItem Content="Mean" Tag="{x:Static local1:MaskMode.Mean}"/>
                                        <ComboBoxItem Content="BandPixel" Tag="{x:Static local1:MaskMode.BandPixel}"/>
                                        <ComboBoxItem Content="MaskRule" Tag="{x:Static local1:MaskMode.MaskRule}"/>
                                    </ComboBox>
                                </DockPanel>

                                <!-- Band Index (BandPixel 모드에서만 표시) -->
                                <DockPanel Margin="0,0,0,10" ToolTip="BandPixel 모드에서 사용할 밴드 인덱스 (1~255)"
                                           Visibility="{Binding SelectedMaskMode, Converter={StaticResource MaskModeToVisibilityConverter}, ConverterParameter=BandPixel}">
                                    <TextBlock Text="Band Index" Width="200" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding MaskBandIndex, UpdateSourceTrigger=PropertyChanged}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="1" Maximum="255" Value="{Binding MaskBandIndex, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>

                                <!-- Less Than Checkbox (Mean, BandPixel 모드에서만 표시) -->
                                <DockPanel Margin="0,0,0,10" ToolTip="임계값 조건: 값이 임계값보다 작으면(체크) 또는 크면(해제) 배경으로 처리"
                                           Visibility="{Binding SelectedMaskMode, Converter={StaticResource MaskModeToVisibilityConverter}, ConverterParameter=MeanOrBandPixel}">
                                    <TextBlock Text="Threshold: Value &lt; Threshold" Width="200" VerticalAlignment="Center"/>
                                    <CheckBox IsChecked="{Binding MaskLessThan}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                                </DockPanel>

                                <!-- Background Threshold Slider (Mean, BandPixel 모드에서만 표시) -->
                                <DockPanel Margin="0,0,0,10" ToolTip="평균 밴드 강도 임계값. 이 값 이하의 픽셀은 배경으로 처리"
                                           Visibility="{Binding SelectedMaskMode, Converter={StaticResource MaskModeToVisibilityConverter}, ConverterParameter=MeanOrBandPixel}">
                                    <TextBlock Text="Background Threshold" Width="200" VerticalAlignment="Center"/>
                                    <!-- ViewModel 연결된 TextBox: 실제 적용 값 표시 -->
                                    <TextBox x:Name="AppliedValueTextBox" Text="{Binding BackgroundThreshold, StringFormat=F2}" Width="100" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True" MaxLength="10" Opacity="1"/>
                                    <Slider x:Name="BackgroundThresholdSlider" Minimum="0" Maximum="65535" Value="{Binding BackgroundThreshold, UpdateSourceTrigger=Explicit}" 
                                            TickFrequency="1" IsSnapToTickEnabled="False" VerticalAlignment="Center"
                                            SmallChange="1" LargeChange="100" behaviors:SliderValuePopupBehavior.Format="F2">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>

                                <!-- MaskRule 2중 구조 (MaskRule 모드에서만 표시) -->
                                <materialDesign:Card Margin="0,0,0,10" Padding="8"
                                                    Visibility="{Binding SelectedMaskMode, Converter={StaticResource MaskModeToVisibilityConverter}, ConverterParameter=MaskRule}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="MaskRule Conditions" VerticalAlignment="Center" FontWeight="Bold"/>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                <Button Command="{Binding AddMaskRuleGroupAndCommand}" Content="+ AND" 
                                                        Style="{StaticResource MaterialDesignFlatButton}" 
                                                        Foreground="#4CAF50"
                                                        Height="24" Padding="8,0" FontSize="10" Margin="0,0,4,0"/>
                                                <Button Command="{Binding AddMaskRuleGroupOrCommand}" Content="+ OR" 
                                                        Style="{StaticResource MaterialDesignFlatButton}" 
                                                        Foreground="#FF9800"
                                                        Height="24" Padding="8,0" FontSize="10"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <TextBlock Text="각 Condition Group을 추가할 때 AND 또는 OR을 선택하세요." 
                                                    FontSize="10" Foreground="Gray" Margin="0,0,0,8"/>

                                        <!-- 2중 구조: Condition Groups -->
                                        <ItemsControl ItemsSource="{Binding MaskRuleConditions.ConditionGroups}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <materialDesign:Card Margin="0,0,0,8" Padding="8" BorderBrush="Gray" BorderThickness="1">
                                                        <StackPanel>
                                                            <!-- Condition Group Header with AND/OR indicator -->
                                                            <DockPanel Margin="0,0,0,8">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Condition Group" VerticalAlignment="Center" FontWeight="Bold" Foreground="LightBlue"/>
                                                                    <!-- Group AND/OR indicator -->
                                                                    <Border Background="{Binding GroupOperator, Converter={StaticResource OperatorToColorConverter}}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                                                        <TextBlock Text="{Binding GroupOperator}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                                    <!-- AND/OR Rule 추가 버튼 2개 -->
                                                                    <Button Command="{Binding DataContext.AddMaskRuleAndCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                            CommandParameter="{Binding}"
                                                                            Content="+ AND"
                                                                            Style="{StaticResource MaterialDesignFlatButton}"
                                                                            Foreground="#4CAF50"
                                                                            Height="20" Padding="4,0" FontSize="9" Margin="0,0,4,0"/>
                                                                    <Button Command="{Binding DataContext.AddMaskRuleOrCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                            CommandParameter="{Binding}"
                                                                            Content="+ OR"
                                                                            Style="{StaticResource MaterialDesignFlatButton}"
                                                                            Foreground="#FF9800"
                                                                            Height="20" Padding="4,0" FontSize="9" Margin="0,0,4,0"/>
                                                                    <Button Command="{Binding DataContext.RemoveMaskRuleGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                            Width="20" Height="20"
                                                                            ToolTip="Remove Group">
                                                                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                                                                    </Button>
                                                                </StackPanel>
                                                            </DockPanel>

                                                            <!-- Rules within the group (自由롭게 AND/OR 선택) -->
                                                            <ItemsControl ItemsSource="{Binding Conditions}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <materialDesign:Card Margin="0,0,0,4" Padding="6" Background="#2A2A2A">
                                                                            <DockPanel>
                                                                                <!-- Next Operator (AND/OR) indicator -->
                                                                                <Border Background="{Binding NextOperator, Converter={StaticResource OperatorToColorConverter}}" 
                                                                                        CornerRadius="4" Padding="8,4" Margin="0,0,8,0" VerticalAlignment="Center">
                                                                                    <TextBlock Text="{Binding NextOperator}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                                                </Border>

                                                                                <!-- Less Than -->
                                                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0">
                                                                                    <TextBlock Text="&lt;" FontSize="10" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                                    <CheckBox IsChecked="{Binding IsLess}" ToolTip="체크: 값 &lt; Threshold = 배경"/>
                                                                                </StackPanel>

                                                                                <!-- Remove Rule -->
                                                                                <Button Command="{Binding DataContext.RemoveMaskRuleFromGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                                        CommandParameter="{Binding}"
                                                                                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                                        Width="28" Height="28"
                                                                                        Margin="4,0,0,0"
                                                                                        DockPanel.Dock="Right"
                                                                                        VerticalAlignment="Center"
                                                                                        ToolTip="Remove Rule">
                                                                                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                                                                                </Button>

                                                                                <!-- Band Index Slider (2x larger) -->
                                                                                <StackPanel Margin="0,0,16,0" MinWidth="300">
                                                                                    <TextBlock Text="Band" FontSize="10" Foreground="Gray" Margin="0,0,0,2"/>
                                                                                    <DockPanel>
                                                                                        <TextBox Text="{Binding BandIndex, UpdateSourceTrigger=LostFocus}" Width="80" DockPanel.Dock="Right" TextAlignment="Center" FontSize="12" VerticalAlignment="Center"
                                                                                                 behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                                                                         <Slider Minimum="1" Maximum="255" Value="{Binding BandIndex, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                                                                             <i:Interaction.Behaviors>
                                                                                                 <behaviors:SliderDragCompletedBehavior/>
                                                                                                 <behaviors:SliderValuePopupBehavior/>
                                                                                                 <behaviors:SliderButtonBehavior/>
                                                                                             </i:Interaction.Behaviors>
                                                                                         </Slider>
                                                                                    </DockPanel>
                                                                                </StackPanel>

                                                                                <!-- Threshold Slider -->
                                                                                <StackPanel MinWidth="350">
                                                                                    <TextBlock Text="Value" FontSize="10" Foreground="Gray" Margin="0,0,0,2"/>
                                                                                    <DockPanel>
                                                                                        <TextBox Text="{Binding Threshold, UpdateSourceTrigger=LostFocus, StringFormat=N0}" Width="80" DockPanel.Dock="Right" TextAlignment="Center" FontSize="12" VerticalAlignment="Center"
                                                                                                 behaviors:NumericOnlyBehavior.IsEnabled="True" MaxLength="6"/>
                                                                                         <Slider Minimum="1" Maximum="65535" Value="{Binding Threshold, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="False">
                                                                                             <i:Interaction.Behaviors>
                                                                                                 <behaviors:SliderDragCompletedBehavior/>
                                                                                                 <behaviors:SliderValuePopupBehavior/>
                                                                                                 <behaviors:SliderButtonBehavior/>
                                                                                             </i:Interaction.Behaviors>
                                                                                         </Slider>
                                                                                    </DockPanel>
                                                                                </StackPanel>
                                                                            </DockPanel>
                                                                        </materialDesign:Card>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </materialDesign:Card>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Object Tracking (Blob) -->
                        <materialDesign:Card Padding="16">
                            <StackPanel>
                                <TextBlock Text="Object Tracking" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>

                                <DockPanel Margin="0,0,0,10" ToolTip="노이즈 필터: 이 값 이하의 픽셀은 무시">
                                    <TextBlock Text="Min Size (Pixels)" Width="200" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding BlobMinPixels, UpdateSourceTrigger=PropertyChanged}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="1" Maximum="100" Value="{Binding BlobMinPixels, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,10" ToolTip="수직 방향 갭 허용 범위">
                                    <TextBlock Text="Max Line Gap" Width="200" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding BlobLineGap, UpdateSourceTrigger=PropertyChanged}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="0" Maximum="50" Value="{Binding BlobLineGap, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,0" ToolTip="수평/대각선 방향 갭 허용 범위">
                                    <TextBlock Text="Pixel Gap (X)" Width="200" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding BlobPixelGap, UpdateSourceTrigger=PropertyChanged}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="0" Maximum="50" Value="{Binding BlobPixelGap, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 3. FEEDER TAB -->
            <!-- AI가 작성함: 피더 제어 탭 전체 구현 -->
            <TabItem Width="{StaticResource TabControlWidth}" Height="60">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Factory" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Feeder" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel MaxWidth="1200" HorizontalAlignment="Stretch">
                        <TextBlock Text="Feeder Control" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,20"/>

                        <!-- 시리얼 포트 연결 카드 -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Serial Port 연결" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>

                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Serial Port" Width="180" VerticalAlignment="Center"/>
                                    <Button Content="↻" Command="{Binding RefreshSerialPortsCommand}" 
                                            Style="{StaticResource MaterialDesignIconButton}" DockPanel.Dock="Right" Width="32" Height="32" ToolTip="새로고침"/>
                                    <ComboBox ItemsSource="{Binding AvailableSerialPorts}" SelectedItem="{Binding SelectedSerialPort}"/>
                                </DockPanel>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding ConnectSerialPortCommand}" Content="Connect" Margin="0,0,8,0"
                                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                                    <!-- Disconnect는 ShutDown 메서드가 필요하나 현재 UI에서 필요 시 추가 가능 -->
                                    <TextBlock Grid.Column="1" Text="{Binding FeederStatusText}" VerticalAlignment="Center" Foreground="Gray" FontSize="12" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 피더 개수 설정 카드 -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Feeder Count" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel>
                                    <TextBlock Text="피더 개수 (0~9)" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding FeederCount}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="0" Maximum="9" Value="{Binding FeederCount, UpdateSourceTrigger=Explicit}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 피더 리스트 카드 -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 제목 -->
                                <TextBlock Grid.Row="0" Text="Feeder Output" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>

                                <!-- 구분선 -->
                                <Border Grid.Row="1" Height="1" Background="{DynamicResource MaterialDesign.Brush.Divider}" Margin="0,0,0,16"/>

                                <!-- 개별 피더 리스트 -->
                                <ItemsControl Grid.Row="2" ItemsSource="{Binding FeederList}" Margin="0,0,0,16">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <materialDesign:Card Margin="0,0,0,8" Padding="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="32"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="32"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 피더 번호 -->
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="14" FontWeight="Medium">
                                                        <Run Text="{Binding DisplayNumber, Mode=OneWay}"/>
                                                        <Run Text="번 피더"/>
                                                    </TextBlock>

                                                    <!-- 감소 버튼 -->
                                                    <!-- <Button Grid.Column="1"
                                                            Command="{Binding DataContext.DecreaseFeederValueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconButton}"
                                                            Width="28" Height="28" VerticalAlignment="Center">
                                                        <materialDesign:PackIcon Kind="Minus" Width="16" Height="16"/>
                                                    </Button> -->

                                                    <!-- 슬라이더 -->
                                                    <Slider Grid.Column="2" Margin="8,0"
                                                            Minimum="1" Maximum="99"
                                                            Value="{Binding FeederValue, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                            TickFrequency="1" TickPlacement="None" IsSnapToTickEnabled="False"
                                                            VerticalAlignment="Center">
                                                        <i:Interaction.Behaviors>
                                                            <behaviors:SliderDragCompletedBehavior 
                                                                Command="{Binding DataContext.FeederSliderDragCompletedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                            <behaviors:SliderValuePopupBehavior/>
                                                            <behaviors:SliderButtonBehavior/>
                                                        </i:Interaction.Behaviors>
                                                    </Slider>

                                                    <!-- 증가 버튼 -->
                                                    <!-- <Button Grid.Column="3"
                                                            Command="{Binding DataContext.IncreaseFeederValueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconButton}"
                                                            Width="28" Height="28" VerticalAlignment="Center">
                                                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"/>
                                                    </Button> -->

                                                    <!-- 값 배지 -->
                                                    <Border Grid.Column="4"
                                                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                            CornerRadius="12" Padding="8,4"
                                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBox Text="{Binding FeederValue, StringFormat='{}{0}', UpdateSourceTrigger=PropertyChanged}"
                                                                   FontSize="14" FontWeight="Bold" Foreground="White"
                                                                   Background="Transparent" BorderThickness="0"
                                                                   HorizontalAlignment="Center" TextAlignment="Center"
                                                                   Width="30"
                                                                   behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                                    </Border>
                                                </Grid>
                                            </materialDesign:Card>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 전체 제어 행 -->
                                <materialDesign:Card Grid.Row="3" Padding="12"
                                                     Background="{DynamicResource MaterialDesign.Brush.Secondary.Light}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="전체 제어" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>

                                        <!-- <Button Grid.Column="1" Command="{Binding DecreaseAllFeederValueCommand}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Width="28" Height="28" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="Minus" Width="16" Height="16"/>
                                        </Button> -->

                                        <Slider Grid.Column="2" Margin="8,0"
                                                Minimum="1" Maximum="99"
                                                Value="{Binding AllFeederValue, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                TickFrequency="1" TickPlacement="None" IsSnapToTickEnabled="False"
                                                VerticalAlignment="Center">
                                            <i:Interaction.Behaviors>
                                                <behaviors:SliderDragCompletedBehavior 
                                                    Command="{Binding DataContext.FeederSliderDragCompletedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="AllFeederValue"/>
                                                <behaviors:SliderValuePopupBehavior/>
                                                <behaviors:SliderButtonBehavior/>
                                            </i:Interaction.Behaviors>
                                        </Slider>

                                        <!-- 전체 증가 버튼 (현재 비활성화)
                                        <Button Grid.Column="3" Command="{Binding IncreaseAllFeederValueCommand}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Width="28" Height="28" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"/>
                                        </Button> -->

                                        <Border Grid.Column="4"
                                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                CornerRadius="12" Padding="8,4"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding AllFeederValue, StringFormat='{}{0}'}"
                                                       FontSize="14" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </materialDesign:Card>
                            </Grid>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 4. FILE PATH TAB -->
            <TabItem Width="{StaticResource TabControlWidth}" Height="60">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Folder" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="File Path" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel MaxWidth="1200" HorizontalAlignment="Stretch">
                        <TextBlock Text="Paths" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,20"/>
                        
                        <!-- AI가 추가함: 캡처 설정 카드 -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Capture Settings" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Save Directory" Width="140" VerticalAlignment="Center" FontWeight="Medium"/>
                                    <Button DockPanel.Dock="Right" Command="{Binding SelectCaptureDirectoryCommand}" Content="Select Folder"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="8,0" Margin="8,0,0,0"/>
                                    <TextBox Text="{Binding CaptureDirectoryPath}" TextAlignment="Left" VerticalAlignment="Center" IsReadOnly="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="30" Padding="4,4"/>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Base Filename" Width="140" VerticalAlignment="Center" FontWeight="Medium"/>
                                    <TextBox Text="{Binding CaptureBaseName, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Left" VerticalAlignment="Center" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="30" Padding="4,4"/>
                                </DockPanel>
                                
                                <TextBlock Text="※ 데이터 캡처 시 지정된 폴더 하위에 [BaseName]_[Timestamp] 폴더가 자동 생성되며, 현재 로드된 레퍼런스 원본(White/Dark)이 일괄 복사·저장됩니다." 
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- AI가 수정함: HSI Model 로드 버튼 제거, Simulation Data를 캡처 설정과 동일 스타일로 변경 -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Simulation Data" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="ENVI Header" Width="140" VerticalAlignment="Center" FontWeight="Medium"/>
                                    <Button DockPanel.Dock="Right" Command="{Binding SelectDataFileCommand}" Content="Select File"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Padding="8,0" Margin="8,0,0,0"/>
                                    <TextBox Text="{Binding HeaderPath, Mode=OneWay}" TextAlignment="Left" VerticalAlignment="Center" IsReadOnly="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="30" Padding="4,4"/>
                                </DockPanel>

                                <Separator Margin="0,16"/>

                                <TextBlock Text="Target FPS (Simulation Only)" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Target FPS" Width="180" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding TargetFps, StringFormat=N0}" Width="80" DockPanel.Dock="Right" TextAlignment="Right"
                                             behaviors:NumericOnlyBehavior.IsEnabled="True"/>
                                    <Slider Minimum="10" Maximum="1000" Value="{Binding TargetFps}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:SliderDragCompletedBehavior/>
                                            <behaviors:SliderValuePopupBehavior/>
                                            <behaviors:SliderButtonBehavior/>
                                        </i:Interaction.Behaviors>
                                    </Slider>
                                </DockPanel>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 5. LANGUAGE TAB -->
            <TabItem Width="{StaticResource TabControlWidth}" Height="60">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Translate" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Language" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <TextBlock Text="Language Settings (Coming Soon)" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" FontSize="20"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
